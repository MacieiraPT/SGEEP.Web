{
  "ConnectionStrings": {
    // Set via environment variable: ConnectionStrings__DefaultConnection
    // e.g. export ConnectionStrings__DefaultConnection="User Id=...;Password=...;Server=...;Port=5432;Database=postgres"
    "DefaultConnection": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Email": {
    "ServidorSmtp": "",
    "Porta": 587,
    "UsarSsl": true,
    "Utilizador": "",
    "Palavra": "",
    "NomeRemetente": "SGEEP",
    "EmailRemetente": ""
  },
  "Supabase": {
    // URL do projeto Supabase. Dashboard → Project Settings → API → Project URL.
    "Url": "https://<project-ref>.supabase.co",
    // service_role key. NUNCA cometer; preferir variável de ambiente:
    //   Supabase__ServiceKey
    // Dashboard → Project Settings → API → service_role secret.
    "ServiceKey": "",
    // Bucket onde os relatórios são guardados. Deve existir no Supabase e ser
    // privado (Dashboard → Storage → New bucket → "Private bucket").
    "NomeBucket": "relatorios",
    // Tempo de vida (segundos) dos URLs assinados de download. 60s é
    // suficiente para o browser iniciar a descarga.
    "SignedUrlSegundos": 60,
    // Timeout (segundos) para upload contra o Supabase.
    "TimeoutSegundos": 60
  },
  "Seed": {
    // Email e password do administrador inicial. Se a password ficar vazia,
    // o sistema gera uma aleatória e regista-a UMA vez nos logs no primeiro
    // arranque — o operador deve mudar a password no primeiro acesso.
    "AdminEmail": "admin@sgeep.pt",
    "AdminPassword": ""
  }
}
