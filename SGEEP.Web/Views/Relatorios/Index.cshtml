@model IEnumerable<SGEEP.Core.Entities.Relatorio>
@using SGEEP.Core.Enums
@{
    ViewData["Title"] = "Relatórios";
    var estagio = ViewBag.Estagio as SGEEP.Core.Entities.Estagio;
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="bi bi-file-text"></i> Relatórios</h2>
            <p class="text-muted mb-0">
                <strong>@estagio?.Aluno?.Nome</strong> —
                @estagio?.Empresa?.Nome
            </p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Estagios" asp-action="Details"
               asp-route-id="@estagio?.Id" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Voltar ao Estágio
            </a>
            @if (User.IsInRole("Aluno") && estagio?.Estado == EstadoEstagio.Ativo)
            {
                <a asp-action="Create" asp-route-estagioId="@estagio?.Id"
                   class="btn btn-primary">
                    <i class="bi bi-plus-lg"></i> Submeter Relatório
                </a>
            }
        </div>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["Sucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @TempData["Erro"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        @foreach (var relatorio in Model)
        {
            <div class="col-md-6">
                <div class="card shadow h-100">
                    <div class="card-header d-flex justify-content-between align-items-center
                        @(relatorio.Estado == EstadoRelatorio.Aprovado ? "bg-success" :
                          relatorio.Estado == EstadoRelatorio.Rejeitado ? "bg-danger" :
                          relatorio.Estado == EstadoRelatorio.Submetido ? "bg-primary" : "bg-secondary") text-white">
                        <h6 class="mb-0">
                            <i class="bi bi-file-earmark-text"></i> @relatorio.Titulo
                        </h6>
                        <span class="badge bg-white text-dark">@relatorio.Estado</span>
                    </div>
                    <div class="card-body">
                        @if (relatorio.Descricao != null)
                        {
                            <p class="text-muted small">@relatorio.Descricao</p>
                        }
                        <p class="small mb-1">
                            <i class="bi bi-calendar"></i>
                            Submetido: @relatorio.DataSubmissao.ToString("dd/MM/yyyy HH:mm")
                        </p>
                        @if (relatorio.ComentarioProfessor != null)
                        {
                            <div class="alert alert-info small mt-2 mb-0">
                                <i class="bi bi-chat-text"></i>
                                <strong>Comentário:</strong> @relatorio.ComentarioProfessor
                            </div>
                        }
                    </div>
                    <div class="card-footer d-flex gap-2 justify-content-end">
                        @if (relatorio.FicheiroPath != null)
                        {
                            <a asp-action="Download" asp-route-id="@relatorio.Id"
                               class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-download"></i> Download
                            </a>
                        }
                        @if ((User.IsInRole("Administrador") || User.IsInRole("Professor"))
                            && relatorio.Estado == EstadoRelatorio.Submetido)
                        {
                            <a asp-action="Avaliar" asp-route-id="@relatorio.Id"
                               class="btn btn-sm btn-warning">
                                <i class="bi bi-star"></i> Avaliar
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="text-center text-muted py-5">
                    <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                    Nenhum relatório submetido ainda.
                </div>
            </div>
        }
    </div>
</div>