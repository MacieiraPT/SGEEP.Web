@model SGEEP.Web.Models.ViewModels.ImportResultadoViewModel
@{
    ViewData["Title"] = "Resultado da Importação";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <h2 class="mb-4">
                <i class="bi bi-clipboard-check"></i> Resultado da Importação — @Model.TipoImportacao
            </h2>

            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="card bg-light">
                        <div class="card-body text-center">
                            <h3>@Model.TotalLinhas</h3>
                            <small class="text-muted">Total de linhas</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-success bg-opacity-10">
                        <div class="card-body text-center">
                            <h3 class="text-success">@Model.Sucesso</h3>
                            <small class="text-muted">Importados com sucesso</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-danger bg-opacity-10">
                        <div class="card-body text-center">
                            <h3 class="text-danger">@Model.Erros</h3>
                            <small class="text-muted">Erros</small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>Linha</th>
                                    <th>Nome</th>
                                    <th>Estado</th>
                                    <th>Mensagem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in Model.Resultados)
                                {
                                    <tr class="@(r.Importado ? "" : "table-danger")">
                                        <td>@r.Linha</td>
                                        <td><strong>@r.Nome</strong></td>
                                        <td>
                                            @if (r.Importado)
                                            {
                                                <span class="badge bg-success">
                                                    <i class="bi bi-check-circle"></i> Importado
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">
                                                    <i class="bi bi-x-circle"></i> Erro
                                                </span>
                                            }
                                        </td>
                                        <td>@r.Mensagem</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="mt-3">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Nova Importação
                </a>
            </div>
        </div>
    </div>
</div>
