@model SGEEP.Web.Models.PaginatedList<SGEEP.Core.Entities.Estagio>
@using SGEEP.Core.Enums
@{
    ViewData["Title"] = "Estágios";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-briefcase"></i> Estágios</h2>
        <div class="d-flex gap-2">
            <a asp-controller="Export" asp-action="EstagiosExcel" class="btn btn-success">
                <i class="bi bi-file-earmark-excel"></i> Excel
            </a>
            <a asp-controller="Export" asp-action="EstagiosPdf" class="btn btn-danger">
                <i class="bi bi-file-earmark-pdf"></i> PDF
            </a>
            @if (User.IsInRole("Professor") && ViewBag.EhDiretorCurso == true)
            {
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-lg"></i> Novo Estágio
                </a>
            }
        </div>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["Sucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @TempData["Erro"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow">
        <div class="card-header bg-white">
            <form method="get" class="d-flex gap-2 flex-wrap">
                <input type="text" name="pesquisa" value="@ViewBag.Pesquisa"
                       class="form-control w-auto" placeholder="Pesquisar aluno ou empresa...">
                <select name="estado" class="form-select w-auto">
                    <option value="">Todos os estados</option>
                    @foreach (var estadoOpcao in Enum.GetValues<SGEEP.Core.Enums.EstadoEstagio>())
                    {
                        if (ViewBag.Estado?.ToString() == ((int)estadoOpcao).ToString())
                        {
                            <option value="@((int)estadoOpcao)" selected>@estadoOpcao</option>
                        }
                        else
                        {
                            <option value="@((int)estadoOpcao)">@estadoOpcao</option>
                        }
                    }
                </select>
                <button type="submit" class="btn btn-outline-primary">
                    <i class="bi bi-search"></i>
                </button>
                @if (!string.IsNullOrEmpty(ViewBag.Pesquisa) || ViewBag.Estado != null)
                {
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-x-lg"></i>
                    </a>
                }
            </form>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Aluno</th>
                            <th>Empresa</th>
                            <th>Professor</th>
                            <th>Início</th>
                            <th>Fim</th>
                            <th>Horas</th>
                            <th>Estado</th>
                            <th class="text-center">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var estagio in Model)
                        {
                            <tr>
                                <td><strong>@estagio.Aluno?.Nome</strong></td>
                                <td>@estagio.Empresa?.Nome</td>
                                <td>@estagio.Professor?.Nome</td>
                                <td>@estagio.DataInicio.ToString("dd/MM/yyyy")</td>
                                <td>@estagio.DataFim.ToString("dd/MM/yyyy")</td>
                                <td>@estagio.TotalHorasPrevistas h</td>
                                <td>
                                    @switch (estagio.Estado)
                                    {
                                        case EstadoEstagio.Pendente:
                                            <span class="badge bg-warning text-dark">Pendente</span>
                                            break;
                                        case EstadoEstagio.Ativo:
                                            <span class="badge bg-success">Ativo</span>
                                            break;
                                        case EstadoEstagio.Concluido:
                                            <span class="badge bg-primary">Concluído</span>
                                            break;
                                        case EstadoEstagio.Cancelado:
                                            <span class="badge bg-danger">Cancelado</span>
                                            break;
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-action="Details" asp-route-id="@estagio.Id"
                                       class="btn btn-sm btn-outline-info" title="Ver">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (User.IsInRole("Administrador") || ViewBag.EhDiretorCurso == true)
                                    {
                                        @if (estagio.Estado == EstadoEstagio.Pendente)
                                        {
                                            <a asp-action="Edit" asp-route-id="@estagio.Id"
                                               class="btn btn-sm btn-outline-warning" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <button type="button" class="btn btn-sm btn-outline-success"
                                                    title="Ativar"
                                                    onclick="confirmarAtivar(@estagio.Id, '@estagio.Aluno?.Nome')">
                                                <i class="bi bi-play-fill"></i>
                                            </button>
                                            <button type="button" class="btn btn-sm btn-outline-danger"
                                                    title="Cancelar"
                                                    onclick="confirmarCancelar(@estagio.Id, '@estagio.Aluno?.Nome')">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        }
                                        @if (estagio.Estado == EstadoEstagio.Ativo)
                                        {
                                            <a asp-action="Concluir" asp-route-id="@estagio.Id"
                                               class="btn btn-sm btn-outline-primary" title="Concluir e Avaliar">
                                                <i class="bi bi-check2-all"></i>
                                            </a>
                                            <button type="button" class="btn btn-sm btn-outline-danger"
                                                    title="Cancelar"
                                                    onclick="confirmarCancelar(@estagio.Id, '@estagio.Aluno?.Nome')">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        }
                                    }
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                                    Nenhum estágio encontrado.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (Model.TotalPages > 1)
            {
                <nav class="d-flex justify-content-center py-3">
                    <ul class="pagination mb-0">
                        <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-pagina="@(Model.PageIndex - 1)"
                               asp-route-pesquisa="@ViewBag.Pesquisa"
                               asp-route-estado="@ViewBag.Estado">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                                <a class="page-link" asp-action="Index"
                                   asp-route-pagina="@i"
                                   asp-route-pesquisa="@ViewBag.Pesquisa"
                                   asp-route-estado="@ViewBag.Estado">@i</a>
                            </li>
                        }
                        <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-pagina="@(Model.PageIndex + 1)"
                               asp-route-pesquisa="@ViewBag.Pesquisa"
                               asp-route-estado="@ViewBag.Estado">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>

<!-- Modal Ativar -->
<div class="modal fade" id="modalAtivar" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">
                    <i class="bi bi-play-fill"></i> Confirmar Ativação
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Tens a certeza que queres ativar o estágio de <strong id="nomeAtivar"></strong>?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary"
                        data-bs-dismiss="modal">Cancelar</button>
                <form id="formAtivar" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-play-fill"></i> Ativar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal Cancelar -->
<div class="modal fade" id="modalCancelar" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle"></i> Confirmar Cancelamento
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Tens a certeza que queres cancelar o estágio de <strong id="nomeCancelar"></strong>?
                Esta ação não pode ser revertida.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary"
                        data-bs-dismiss="modal">Voltar</button>
                <form id="formCancelar" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-x-lg"></i> Cancelar Estágio
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmarAtivar(id, nome) {
            document.getElementById('nomeAtivar').textContent = nome;
            document.getElementById('formAtivar').action = '/Estagios/Ativar/' + id;
            new bootstrap.Modal(document.getElementById('modalAtivar')).show();
        }

        function confirmarCancelar(id, nome) {
            document.getElementById('nomeCancelar').textContent = nome;
            document.getElementById('formCancelar').action = '/Estagios/Cancelar/' + id;
            new bootstrap.Modal(document.getElementById('modalCancelar')).show();
        }
    </script>
}
