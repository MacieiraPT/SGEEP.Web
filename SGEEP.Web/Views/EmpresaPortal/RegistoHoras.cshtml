@model SGEEP.Core.Entities.Estagio
@using SGEEP.Core.Enums
@{
    ViewData["Title"] = "Registo de Horas - " + Model.Aluno?.Nome;
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-clock-history"></i> Registo de Horas</h2>
        <a asp-action="MeusEstagios" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Voltar
        </a>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Sucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Erro"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <strong>Aluno:</strong> @Model.Aluno?.Nome
                </div>
                <div class="col-md-4">
                    <strong>Período:</strong> @Model.DataInicio.ToString("dd/MM/yyyy") - @Model.DataFim.ToString("dd/MM/yyyy")
                </div>
                <div class="col-md-4">
                    @{
                        var horasValidadas = Model.RegistoHoras.Where(r => r.Estado == EstadoHoras.Validado).Sum(r => r.TotalHoras);
                        var percentagem = Model.TotalHorasPrevistas > 0 ? (horasValidadas / Model.TotalHorasPrevistas) * 100 : 0;
                    }
                    <strong>Progresso:</strong> @horasValidadas.ToString("F1")h / @Model.TotalHorasPrevistas h
                    <div class="progress mt-1" style="height: 8px;">
                        <div class="progress-bar bg-success" style="width: @percentagem.ToString("F0")%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-header bg-white">
            <h5 class="mb-0">Registos</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.RegistoHoras.Any())
            {
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Data</th>
                            <th>Entrada</th>
                            <th>Saída</th>
                            <th>Pausa</th>
                            <th>Total</th>
                            <th>Observações</th>
                            <th>Estado</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.RegistoHoras)
                        {
                            <tr>
                                <td>@r.Data.ToString("dd/MM/yyyy")</td>
                                <td>@r.HoraEntrada.ToString("HH:mm")</td>
                                <td>@r.HoraSaida.ToString("HH:mm")</td>
                                <td>@(r.HoraPausa?.ToString("HH:mm") ?? "-")</td>
                                <td><strong>@r.TotalHoras.ToString("F1")h</strong></td>
                                <td>@(r.Observacoes ?? "-")</td>
                                <td>
                                    @switch (r.Estado)
                                    {
                                        case EstadoHoras.Pendente:
                                            <span class="badge bg-warning text-dark">Pendente</span>
                                            break;
                                        case EstadoHoras.Validado:
                                            <span class="badge bg-success">Validado</span>
                                            break;
                                        case EstadoHoras.Rejeitado:
                                            <span class="badge bg-danger">Rejeitado</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    @if (r.Estado == EstadoHoras.Pendente)
                                    {
                                        <form asp-action="ValidarHoras" asp-route-id="@r.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-success" title="Validar">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </form>
                                        <button type="button" class="btn btn-sm btn-danger" title="Rejeitar"
                                                data-bs-toggle="modal" data-bs-target="#modalRejeitar"
                                                onclick="document.getElementById('rejeitarForm').action='@Url.Action("RejeitarHoras", new { id = r.Id })'">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">
                                            @(r.DataValidacao?.ToString("dd/MM HH:mm") ?? "")
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-clock" style="font-size: 2rem;"></i>
                    <p class="mt-2">Sem registos de horas.</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal Rejeitar -->
<div class="modal fade" id="modalRejeitar" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Confirmar Rejeição</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Tem a certeza que pretende rejeitar este registo de horas?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form id="rejeitarForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Rejeitar</button>
                </form>
            </div>
        </div>
    </div>
</div>
