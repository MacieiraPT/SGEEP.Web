@model SGEEP.Web.Models.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Alterar Password";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">
                        <i class="bi bi-shield-lock"></i> Alterar Password
                    </h5>
                </div>
                <div class="card-body">
                    @if (User.HasClaim("MustChangePassword", "true"))
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle"></i>
                            <strong>Primeiro acesso detetado.</strong>
                            Por razões de segurança, deve alterar a sua password antes de continuar.
                        </div>
                    }

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <form asp-action="ChangePassword" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label asp-for="CurrentPassword" class="form-label"></label>
                            <input asp-for="CurrentPassword" class="form-control" />
                            <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label"></label>
                            <input asp-for="NewPassword" class="form-control" />
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                            <div class="form-text">
                                Mínimo 8 caracteres, 1 maiúscula e 1 dígito.
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label"></label>
                            <input asp-for="ConfirmPassword" class="form-control" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                        <hr />
                        <div class="d-flex gap-2 justify-content-end">
                            @if (!User.HasClaim("MustChangePassword", "true"))
                            {
                                <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
                                    <i class="bi bi-arrow-left"></i> Cancelar
                                </a>
                            }
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-check-lg"></i> Alterar Password
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
