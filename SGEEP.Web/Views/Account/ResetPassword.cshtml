@{
    ViewData["Title"] = "Repor Password";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-key"></i> Repor Password
                    </h5>
                </div>
                <div class="card-body">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle"></i>
                        Vai gerar uma nova password temporária para o utilizador
                        <strong>@ViewBag.TargetEmail</strong>.
                        O utilizador será obrigado a alterar a password no próximo login.
                    </div>

                    <form asp-action="ResetPassword" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="userId" value="@ViewBag.TargetUserId" />
                        <input type="hidden" name="dummy" value="1" />
                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="GerirUtilizadores" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-key"></i> Gerar Nova Password
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
