@model List<Microsoft.AspNetCore.Identity.IdentityUser>
@{
    ViewData["Title"] = "Gerir Utilizadores";
}

<div class="container py-4">
    <h3><i class="bi bi-people"></i> Gerir Utilizadores</h3>
    <hr />

    <form method="get" class="mb-4">
        <div class="input-group" style="max-width: 400px;">
            <input type="text" name="pesquisa" value="@ViewBag.Pesquisa" class="form-control"
                   placeholder="Pesquisar por email..." />
            <button class="btn btn-outline-primary" type="submit">
                <i class="bi bi-search"></i>
            </button>
        </div>
    </form>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["Sucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Email</th>
                        <th>Confirmado</th>
                        <th>Bloqueado</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var isLocked = user.LockoutEnd.HasValue && user.LockoutEnd > DateTimeOffset.UtcNow;
                        <tr>
                            <td>@user.Email</td>
                            <td>
                                @if (user.EmailConfirmed)
                                {
                                    <span class="badge bg-success">Sim</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Não</span>
                                }
                            </td>
                            <td>
                                @if (isLocked)
                                {
                                    <span class="badge bg-danger">Bloqueado</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Ativo</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="ResetPassword" asp-route-userId="@user.Id"
                                   class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-key"></i> Repor Password
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
