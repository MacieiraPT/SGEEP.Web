@model SGEEP.Core.Entities.Aluno
@using SGEEP.Core.Enums
@{
    ViewData["Title"] = "O Meu Estágio";
    var estagioAtivo = Model.Estagios
        .FirstOrDefault(e => e.Estado == EstadoEstagio.Ativo
                          || e.Estado == EstadoEstagio.Pendente);
}

<div class="container-fluid py-2">

    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger">@TempData["Erro"]</div>
    }

    @if (estagioAtivo == null)
    {
        <div class="text-center py-5">
            <i class="bi bi-briefcase fs-1 text-muted d-block mb-3"></i>
            <h5 class="text-muted">Ainda não tens nenhum estágio ativo.</h5>
            <p class="text-muted small">Contacta o teu Diretor de Curso.</p>
        </div>
    }
    else
    {
        <!-- Cards de resumo -->
        <div class="row g-3 mb-4">
            @{
                var horasValidadas = estagioAtivo.RegistoHoras
                .Where(r => r.Estado == EstadoHoras.Validado)
                .Sum(r => r.TotalHoras);
                var percentagem = estagioAtivo.TotalHorasPrevistas > 0
                ? (int)((horasValidadas / estagioAtivo.TotalHorasPrevistas) * 100)
                : 0;
            }
            <div class="col-md-3">
                <div class="card h-100" style="border-left: 4px solid #2563eb !important;">
                    <div class="card-body">
                        <p class="text-muted small mb-1">Estado do Estágio</p>
                        <h5 class="fw-bold mb-0">
                            @if (estagioAtivo.Estado == EstadoEstagio.Ativo)
                            {
                                <span class="text-success">Ativo</span>
                            }
                            else
                            {
                                <span class="text-warning">Pendente</span>
                            }
                        </h5>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100" style="border-left: 4px solid #16a34a !important;">
                    <div class="card-body">
                        <p class="text-muted small mb-1">Horas Validadas</p>
                        <h5 class="fw-bold mb-0">@horasValidadas.ToString("F1") h</h5>
                        <small class="text-muted">de @estagioAtivo.TotalHorasPrevistas h previstas</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100" style="border-left: 4px solid #d97706 !important;">
                    <div class="card-body">
                        <p class="text-muted small mb-1">Relatórios</p>
                        <h5 class="fw-bold mb-0">@estagioAtivo.Relatorios.Count</h5>
                        <small class="text-muted">
                            @estagioAtivo.Relatorios.Count(r => r.Estado == EstadoRelatorio.Aprovado) aprovados
                        </small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100" style="border-left: 4px solid #7c3aed !important;">
                    <div class="card-body">
                        <p class="text-muted small mb-1">Dias Restantes</p>
                        <h5 class="fw-bold mb-0">
                            @Math.Max(0, (estagioAtivo.DataFim - DateTime.Today).Days)
                        </h5>
                        <small class="text-muted">até @estagioAtivo.DataFim.ToString("dd/MM/yyyy")</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Progresso -->
        <div class="card mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span class="fw-semibold">Progresso de Horas</span>
                    <span class="text-muted small">@percentagem%</span>
                </div>
                <div class="progress" style="height: 12px;">
                    <div class="progress-bar @(percentagem >= 100 ? "bg-success" : "bg-primary")"
                         style="width: @Math.Min(percentagem, 100)%"></div>
                </div>
            </div>
        </div>

        <!-- Info do estágio + Ações -->
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header">
                        <h6 class="mb-0"><i class="bi bi-building"></i> Empresa</h6>
                    </div>
                    <div class="card-body">
                        <p class="fw-bold mb-1">@estagioAtivo.Empresa?.Nome</p>
                        <p class="text-muted small mb-1">@estagioAtivo.Empresa?.Cidade</p>
                        <p class="text-muted small mb-1">
                            Tutor: @(estagioAtivo.Empresa?.NomeTutor ?? "—")
                        </p>
                        <p class="text-muted small">
                            @(estagioAtivo.Empresa?.EmailTutor ?? "—")
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header">
                        <h6 class="mb-0"><i class="bi bi-person-workspace"></i> Professor Orientador</h6>
                    </div>
                    <div class="card-body">
                        <p class="fw-bold mb-1">@estagioAtivo.Professor?.Nome</p>
                        <p class="text-muted small">@estagioAtivo.Professor?.Email</p>
                    </div>
                </div>
            </div>

            <!-- Ações rápidas -->
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h6 class="mb-0"><i class="bi bi-lightning"></i> Ações Rápidas</h6>
                    </div>
                    <div class="card-body d-flex gap-3 flex-wrap">
                        @if (estagioAtivo.Estado == EstadoEstagio.Ativo)
                        {
                            <a asp-controller="RegistoHoras" asp-action="Create"
                               asp-route-estagioId="@estagioAtivo.Id"
                               class="btn btn-primary">
                                <i class="bi bi-clock"></i> Registar Horas
                            </a>
                            <a asp-controller="Relatorios" asp-action="Create"
                               asp-route-estagioId="@estagioAtivo.Id"
                               class="btn btn-success">
                                <i class="bi bi-file-earmark-arrow-up"></i> Submeter Relatório
                            </a>
                        }
                        <a asp-controller="RegistoHoras" asp-action="Index"
                           asp-route-estagioId="@estagioAtivo.Id"
                           class="btn btn-outline-primary">
                            <i class="bi bi-clock-history"></i> Ver Horas
                        </a>
                        <a asp-controller="Relatorios" asp-action="Index"
                           asp-route-estagioId="@estagioAtivo.Id"
                           class="btn btn-outline-success">
                            <i class="bi bi-file-text"></i> Ver Relatórios
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>