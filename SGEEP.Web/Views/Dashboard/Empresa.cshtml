@using SGEEP.Core.Entities
@using SGEEP.Core.Enums
@{
    ViewData["Title"] = "Dashboard - Empresa";
    var empresa = (Empresa)ViewBag.Empresa;
    var ultimos = (List<Estagio>)ViewBag.UltimosEstagios;
}

<div class="container-fluid py-4">
    <h2 class="mb-4">
        <i class="bi bi-building"></i> Dashboard — @empresa.Nome
    </h2>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card text-white bg-primary shadow">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-people"></i> Estagiários</h5>
                    <h2 class="card-text">@ViewBag.EstagiariosAtivos</h2>
                    <small>Ativos</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-warning shadow">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-clock-history"></i> Horas por Validar</h5>
                    <h2 class="card-text">@ViewBag.HorasPorValidar</h2>
                    <small>Pendentes</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-success shadow">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-check-circle"></i> Estágios</h5>
                    <h2 class="card-text">@ViewBag.EstagiosConcluidos</h2>
                    <small>Concluídos</small>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-header bg-white">
            <h5 class="mb-0"><i class="bi bi-list-ul"></i> Últimos Estágios</h5>
        </div>
        <div class="card-body p-0">
            @if (ultimos.Any())
            {
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Aluno</th>
                            <th>Professor</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in ultimos)
                        {
                            <tr>
                                <td>@e.Aluno?.Nome</td>
                                <td>@e.Professor?.Nome</td>
                                <td>
                                    @switch (e.Estado)
                                    {
                                        case EstadoEstagio.Pendente:
                                            <span class="badge bg-secondary">Pendente</span>
                                            break;
                                        case EstadoEstagio.Ativo:
                                            <span class="badge bg-primary">Ativo</span>
                                            break;
                                        case EstadoEstagio.Concluido:
                                            <span class="badge bg-success">Concluído</span>
                                            break;
                                        case EstadoEstagio.Cancelado:
                                            <span class="badge bg-danger">Cancelado</span>
                                            break;
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                    <p class="mt-2">Sem estágios registados.</p>
                </div>
            }
        </div>
    </div>
</div>
