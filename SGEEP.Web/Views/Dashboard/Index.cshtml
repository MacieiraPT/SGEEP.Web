@using SGEEP.Core.Enums
@{
    ViewData["Title"] = "Dashboard — Administrador";
}

<div class="container-fluid py-2">

    <!-- KPIs -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card h-100" style="border-left: 4px solid #2563eb !important;">
                <div class="card-body d-flex align-items-center gap-3">
                    <div style="width:48px;height:48px;background:#eff6ff;border-radius:12px;display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-mortarboard fs-4 text-primary"></i>
                    </div>
                    <div>
                        <p class="text-muted small mb-0">Alunos Ativos</p>
                        <h3 class="fw-bold mb-0">@ViewBag.TotalAlunos</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100" style="border-left: 4px solid #16a34a !important;">
                <div class="card-body d-flex align-items-center gap-3">
                    <div style="width:48px;height:48px;background:#f0fdf4;border-radius:12px;display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-briefcase fs-4 text-success"></i>
                    </div>
                    <div>
                        <p class="text-muted small mb-0">Estágios Ativos</p>
                        <h3 class="fw-bold mb-0">@ViewBag.EstagiosAtivos</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100" style="border-left: 4px solid #d97706 !important;">
                <div class="card-body d-flex align-items-center gap-3">
                    <div style="width:48px;height:48px;background:#fffbeb;border-radius:12px;display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-building fs-4 text-warning"></i>
                    </div>
                    <div>
                        <p class="text-muted small mb-0">Empresas Parceiras</p>
                        <h3 class="fw-bold mb-0">@ViewBag.TotalEmpresas</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100" style="border-left: 4px solid #dc2626 !important;">
                <div class="card-body d-flex align-items-center gap-3">
                    <div style="width:48px;height:48px;background:#fef2f2;border-radius:12px;display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-file-text fs-4 text-danger"></i>
                    </div>
                    <div>
                        <p class="text-muted small mb-0">Relatórios Pendentes</p>
                        <h3 class="fw-bold mb-0">@ViewBag.RelatoriosPendentes</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Segunda linha de KPIs -->
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card h-100" style="border-left: 4px solid #7c3aed !important;">
                <div class="card-body d-flex align-items-center gap-3">
                    <div style="width:48px;height:48px;background:#f5f3ff;border-radius:12px;display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-clock fs-4 text-purple" style="color:#7c3aed"></i>
                    </div>
                    <div>
                        <p class="text-muted small mb-0">Registos de Horas por Validar</p>
                        <h3 class="fw-bold mb-0">@ViewBag.HorasPorValidar</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100" style="border-left: 4px solid #0891b2 !important;">
                <div class="card-body d-flex align-items-center gap-3">
                    <div style="width:48px;height:48px;background:#ecfeff;border-radius:12px;display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-hourglass-split fs-4" style="color:#0891b2"></i>
                    </div>
                    <div>
                        <p class="text-muted small mb-0">Estágios Pendentes de Ativação</p>
                        <h3 class="fw-bold mb-0">@ViewBag.EstagiosPendentes</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Últimos estágios -->
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="mb-0"><i class="bi bi-clock-history"></i> Últimos Estágios</h6>
            <a asp-controller="Estagios" asp-action="Index" class="btn btn-sm btn-outline-primary">
                Ver todos
            </a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Aluno</th>
                            <th>Empresa</th>
                            <th>Início</th>
                            <th>Fim</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var estagio in ViewBag.UltimosEstagios)
                        {
                            <tr>
                                <td><strong>@estagio.Aluno?.Nome</strong></td>
                                <td>@estagio.Empresa?.Nome</td>
                                <td>@estagio.DataInicio.ToString("dd/MM/yyyy")</td>
                                <td>@estagio.DataFim.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @switch ((EstadoEstagio)estagio.Estado)
                                    {
                                        case EstadoEstagio.Pendente:
                                            <span class="badge bg-warning text-dark">Pendente</span>
                                            break;
                                        case EstadoEstagio.Ativo:
                                            <span class="badge bg-success">Ativo</span>
                                            break;
                                        case EstadoEstagio.Concluido:
                                            <span class="badge bg-primary">Concluído</span>
                                            break;
                                        case EstadoEstagio.Cancelado:
                                            <span class="badge bg-danger">Cancelado</span>
                                            break;
                                    }
                                </td>
                            </tr>
                        }
                        @if (((IEnumerable<dynamic>)ViewBag.UltimosEstagios).Count() == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    Nenhum estágio registado ainda.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>