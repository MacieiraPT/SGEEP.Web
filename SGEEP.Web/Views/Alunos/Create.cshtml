@model SGEEP.Web.Models.ViewModels.AlunoViewModel
@{
    ViewData["Title"] = "Novo Aluno";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-person-plus"></i> Novo Aluno
                    </h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <div class="row g-3">
                            <div class="col-md-8">
                                <label asp-for="Nome" class="form-label"></label>
                                <input asp-for="Nome" class="form-control"
                                       placeholder="Nome completo do aluno" />
                                <span asp-validation-for="Nome" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="NumeroAluno" class="form-label"></label>
                                <input asp-for="NumeroAluno" class="form-control"
                                       placeholder="Ex: 2024001" />
                                <span asp-validation-for="NumeroAluno" class="text-danger small"></span>
                            </div>
                            <div class="col-md-8">
                                <label asp-for="Email" class="form-label"></label>
                                <input asp-for="Email" class="form-control"
                                       placeholder="email@exemplo.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                            <div class="col-md-8">
                                <label asp-for="NIF" class="form-label"></label>
                                <input asp-for="NIF" class="form-control"
                                       placeholder="123456789" maxlength="9" />
                                <span asp-validation-for="NIF" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Telefone" class="form-label"></label>
                                <input asp-for="Telefone" class="form-control"
                                       placeholder="9XXXXXXXX" />
                                <span asp-validation-for="Telefone" class="text-danger small"></span>
                            </div>
                            @if (ViewBag.CursoFixo == true)
                            {
                                <input type="hidden" asp-for="CursoId" />
                                <div class="col-md-8">
                                    <label class="form-label">Curso</label>
                                    <input class="form-control" disabled
                                           value="@(Model.Cursos.FirstOrDefault(c => c.Value == Model.CursoId.ToString())?.Text ?? "Curso do Professor")" />
                                </div>
                            }
                            else
                            {
                                <div class="col-md-8">
                                    <label asp-for="CursoId" class="form-label"></label>
                                    <select asp-for="CursoId" asp-items="Model.Cursos" class="form-select">
                                        <option value="">-- Seleciona um curso --</option>
                                    </select>
                                    <span asp-validation-for="CursoId" class="text-danger small"></span>
                                </div>
                            }
                            <div class="col-md-4">
                                <label asp-for="Turma" class="form-label"></label>
                                <input asp-for="Turma" class="form-control"
                                       placeholder="Ex: 12ºA" />
                                <span asp-validation-for="Turma" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <div class="form-check form-switch">
                                    <input asp-for="Ativo" class="form-check-input" />
                                    <label asp-for="Ativo" class="form-check-label">Aluno Ativo</label>
                                </div>
                            </div>
                        </div>
                        <hr />
                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg"></i> Guardar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}