@model ErrorViewModel
@{
    Layout = null;

    var code = Model.StatusCode > 0 ? Model.StatusCode : 500;

    string titulo;
    string mensagem;
    string icone;

    switch (code)
    {
        case 400:
            titulo = "Pedido Inválido";
            mensagem = "O pedido enviado não pôde ser processado. Verifique os dados e tente novamente.";
            icone = "bi-x-octagon";
            break;
        case 403:
            titulo = "Acesso Negado";
            mensagem = "Não tem permissão para aceder a esta página. Se acha que isto é um erro, contacte o administrador.";
            icone = "bi-shield-lock";
            break;
        case 404:
            titulo = "Página Não Encontrada";
            mensagem = "A página que procura não existe ou foi movida. Verifique o endereço e tente novamente.";
            icone = "bi-search";
            break;
        case 429:
            titulo = "Demasiados Pedidos";
            mensagem = "Excedeu o limite de pedidos. Aguarde um momento e tente novamente.";
            icone = "bi-hourglass-split";
            break;
        default:
            titulo = "Erro Interno";
            mensagem = "Ocorreu um erro inesperado no servidor. Tente novamente mais tarde ou contacte o administrador.";
            icone = "bi-exclamation-triangle";
            break;
    }
}

<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@code — SGEEP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/css/sgeep-theme.css" rel="stylesheet" />
    <style>
        .error-shell {
            min-height: 100vh;
            background: var(--sg-canvas);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 32px 16px;
        }
        .error-container {
            text-align: center;
            max-width: 520px;
        }
        .error-brand {
            font-family: var(--sg-font-display);
            font-weight: 600;
            font-size: 1.125rem;
            letter-spacing: -0.04em;
            color: var(--sg-ink);
            margin-bottom: 48px;
        }
        .error-code {
            font-family: var(--sg-font-display);
            font-size: 6rem;
            font-weight: 600;
            line-height: 1;
            letter-spacing: -0.06em;
            color: var(--sg-ink);
            margin: 0 0 8px;
        }
        .error-icon {
            font-size: 2rem;
            color: var(--sg-muted);
            margin-bottom: 8px;
            display: inline-block;
        }
        .error-title {
            font-family: var(--sg-font-display);
            font-size: 1.75rem;
            font-weight: 600;
            letter-spacing: -0.03em;
            color: var(--sg-ink);
            margin: 16px 0 12px;
        }
        .error-message {
            color: var(--sg-muted);
            font-size: 1rem;
            line-height: 1.6;
            margin-bottom: 32px;
        }
        .request-id {
            font-size: 0.75rem;
            color: var(--sg-muted-soft);
            margin-top: 32px;
        }
        .request-id code {
            color: var(--sg-muted);
            background: var(--sg-surface-soft);
            padding: 2px 6px;
            border-radius: var(--sg-radius-sm);
        }
    </style>
</head>
<body>
    <div class="error-shell">
        <div class="error-container">
            <div class="error-brand">SGEEP</div>

            <div class="error-icon">
                <i class="bi @icone"></i>
            </div>
            <div class="error-code">@code</div>

            <h1 class="error-title">@titulo</h1>
            <p class="error-message">@mensagem</p>

            <div class="d-flex gap-2 justify-content-center flex-wrap">
                <a href="/" class="btn btn-primary">
                    <i class="bi bi-house me-1"></i> Página Inicial
                </a>
                @if (code == 403)
                {
                    <a href="/Identity/Account/Login" class="btn btn-secondary">
                        Iniciar Sessão
                    </a>
                }
                else
                {
                    <a href="javascript:history.back()" class="btn btn-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Voltar
                    </a>
                }
            </div>

            @if (Model.ShowRequestId)
            {
                <p class="request-id">
                    ID do pedido: <code>@Model.RequestId</code>
                </p>
            }
        </div>
    </div>
</body>
</html>
