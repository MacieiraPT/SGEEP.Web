@*
    SGEEP layout — follows /DESIGN.md (Cal.com-inspired):
    white canvas, light sidebar, black primary CTAs, Inter body.
    All component styling lives in /css/sgeep-theme.css.
*@
<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SGEEP</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/css/sgeep-theme.css" rel="stylesheet" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    @if (User.Identity?.IsAuthenticated == true)
    {
        var initial = string.IsNullOrEmpty(User.Identity.Name)
            ? "?"
            : User.Identity.Name.Substring(0, 1).ToUpperInvariant();
        var displayName = User.Identity.Name?.Split('@')[0] ?? "Utilizador";
        string role =
            User.IsInRole("Administrador") ? "Administrador" :
            User.IsInRole("Professor")     ? "Professor" :
            User.IsInRole("Aluno")         ? "Aluno" :
            User.IsInRole("Empresa")       ? "Tutor de Empresa" : "Utilizador";
        string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
        string currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
        bool IsActive(string controller, string? action = null) =>
            currentController == controller && (action == null || currentAction == action);

        <nav id="sidebar" aria-label="Navegação principal">
            <div class="sidebar-brand">
                <h4>SGEEP</h4>
                <small>Sistema de Gestão de Estágios</small>
            </div>

            <div class="user-card d-flex align-items-center gap-2">
                <div class="user-avatar">@initial</div>
                <div>
                    <p class="user-name">@displayName</p>
                    <p class="user-role">@role</p>
                </div>
            </div>

            <ul class="nav flex-column pb-4">
                <li class="nav-item">
                    <a class="nav-link @(IsActive("Dashboard") ? "active" : "")"
                       asp-controller="Home" asp-action="Index">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                </li>

                @if (User.IsInRole("Administrador") || User.IsInRole("Professor"))
                {
                    <div class="nav-section">Gestão</div>
                    <li class="nav-item">
                        <a class="nav-link @(IsActive("Alunos") ? "active" : "")"
                           asp-controller="Alunos" asp-action="Index">
                            <i class="bi bi-mortarboard"></i> Alunos
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(IsActive("Empresas") ? "active" : "")"
                           asp-controller="Empresas" asp-action="Index">
                            <i class="bi bi-building"></i> Empresas
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(IsActive("Estagios") ? "active" : "")"
                           asp-controller="Estagios" asp-action="Index">
                            <i class="bi bi-briefcase"></i> Estágios
                        </a>
                    </li>
                }

                @if (User.IsInRole("Administrador"))
                {
                    <li class="nav-item">
                        <a class="nav-link @(IsActive("Professores") ? "active" : "")"
                           asp-controller="Professores" asp-action="Index">
                            <i class="bi bi-person-workspace"></i> Professores
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(IsActive("Cursos") ? "active" : "")"
                           asp-controller="Cursos" asp-action="Index">
                            <i class="bi bi-book"></i> Cursos
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(IsActive("Import") ? "active" : "")"
                           asp-controller="Import" asp-action="Index">
                            <i class="bi bi-upload"></i> Importar Dados
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(IsActive("Auditoria") ? "active" : "")"
                           asp-controller="Auditoria" asp-action="Index">
                            <i class="bi bi-shield-check"></i> Auditoria
                        </a>
                    </li>
                }

                @if (User.IsInRole("Aluno"))
                {
                    <div class="nav-section">O Meu Estágio</div>
                    <li class="nav-item">
                        <a class="nav-link @(IsActive("Aluno", "MeuEstagio") ? "active" : "")"
                           asp-controller="Aluno" asp-action="MeuEstagio">
                            <i class="bi bi-briefcase"></i> O Meu Estágio
                        </a>
                    </li>
                }

                @if (User.IsInRole("Empresa"))
                {
                    <div class="nav-section">Portal Empresa</div>
                    <li class="nav-item">
                        <a class="nav-link @(IsActive("EmpresaPortal", "MeusEstagios") ? "active" : "")"
                           asp-controller="EmpresaPortal" asp-action="MeusEstagios">
                            <i class="bi bi-briefcase"></i> Meus Estágios
                        </a>
                    </li>
                }

                <div class="nav-section">Conta</div>

                @if (User.IsInRole("Administrador"))
                {
                    <li class="nav-item">
                        <a class="nav-link @(IsActive("Account", "GerirUtilizadores") ? "active" : "")"
                           asp-controller="Account" asp-action="GerirUtilizadores">
                            <i class="bi bi-people"></i> Utilizadores
                        </a>
                    </li>
                }

                <li class="nav-item">
                    <a class="nav-link @(IsActive("Notificacoes") ? "active" : "")"
                       asp-controller="Notificacoes" asp-action="Index">
                        <i class="bi bi-bell"></i> Notificações
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-area="Identity" asp-page="/Account/Manage/Index">
                        <i class="bi bi-person-gear"></i> O Meu Perfil
                    </a>
                </li>

                <li class="nav-item">
                    <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="nav-link border-0 bg-transparent w-100 text-start">
                            <i class="bi bi-box-arrow-left"></i> Terminar Sessão
                        </button>
                    </form>
                </li>
            </ul>
        </nav>

        <div id="topbar">
            <button class="btn btn-sm btn-outline-secondary d-md-none"
                    onclick="document.getElementById('sidebar').classList.toggle('show')"
                    aria-label="Abrir menu">
                <i class="bi bi-list"></i>
            </button>
            <span class="page-title">@ViewData["Title"]</span>

            <div class="d-flex align-items-center gap-3">
                @await Component.InvokeAsync("NotificacaoBadge")
                <span class="text-muted small d-none d-md-block">
                    @DateTime.Now.ToString("dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("pt-PT"))
                </span>
            </div>
        </div>

        <main id="main-content">
            @RenderBody()
        </main>
    }
    else
    {
        <main>
            @RenderBody()
        </main>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
