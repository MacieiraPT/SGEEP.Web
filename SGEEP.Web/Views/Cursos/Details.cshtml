@model SGEEP.Core.Entities.Curso
@{
    ViewData["Title"] = "Detalhes do Curso";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-info text-white d-flex justify-content-between">
                    <h5 class="mb-0">
                        <i class="bi bi-book"></i> @Model.Nome
                    </h5>
                    <span class="badge @(Model.Ativo ? "bg-success" : "bg-danger") fs-6">
                        @(Model.Ativo ? "Ativo" : "Inativo")
                    </span>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="text-muted small">Código</label>
                            <p class="fw-bold">@Model.Codigo</p>
                        </div>
                        <div class="col-md-8">
                            <label class="text-muted small">Nome</label>
                            <p class="fw-bold">@Model.Nome</p>
                        </div>
                        <div class="col-12">
                            <label class="text-muted small">Descrição</label>
                            <p class="fw-bold">@(Model.Descricao ?? "—")</p>
                        </div>
                    </div>

                    @if (Model.Professores.Any())
                    {
                        <hr />
                        <h6><i class="bi bi-person-workspace"></i> Professores (@Model.Professores.Count)</h6>
                        <ul class="list-unstyled">
                            @foreach (var prof in Model.Professores)
                            {
                                <li>
                                    <i class="bi bi-person"></i> @prof.Nome
                                    @if (prof.DiretorCurso)
                                    {
                                        <span class="badge bg-warning text-dark">DC</span>
                                    }
                                    @if (!prof.Ativo)
                                    {
                                        <span class="badge bg-danger">Inativo</span>
                                    }
                                </li>
                            }
                        </ul>
                    }

                    @if (Model.Alunos.Any())
                    {
                        <hr />
                        <h6><i class="bi bi-mortarboard"></i> Alunos (@Model.Alunos.Count)</h6>
                        <p class="text-muted">@Model.Alunos.Count(a => a.Ativo) ativos</p>
                    }
                </div>
                <div class="card-footer d-flex gap-2 justify-content-end">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Voltar
                    </a>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                        <i class="bi bi-pencil"></i> Editar
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
