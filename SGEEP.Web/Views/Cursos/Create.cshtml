@model SGEEP.Web.Models.ViewModels.CursoViewModel
@{
    ViewData["Title"] = "Novo Curso";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-plus-lg"></i> Novo Curso
                    </h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <div class="row g-3">
                            <div class="col-md-8">
                                <label asp-for="Nome" class="form-label"></label>
                                <input asp-for="Nome" class="form-control"
                                       placeholder="Nome completo do curso" />
                                <span asp-validation-for="Nome" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Codigo" class="form-label"></label>
                                <input asp-for="Codigo" class="form-control"
                                       placeholder="Ex: PRG" maxlength="20" />
                                <span asp-validation-for="Codigo" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="Descricao" class="form-label"></label>
                                <textarea asp-for="Descricao" class="form-control" rows="3"
                                          placeholder="Descrição do curso (opcional)"></textarea>
                                <span asp-validation-for="Descricao" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <div class="form-check form-switch">
                                    <input asp-for="Ativo" class="form-check-input" />
                                    <label asp-for="Ativo" class="form-check-label">Curso Ativo</label>
                                </div>
                            </div>
                        </div>
                        <hr />
                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg"></i> Guardar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
