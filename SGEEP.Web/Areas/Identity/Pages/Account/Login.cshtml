@page
@model LoginModel
@{
    ViewData["Title"] = "Iniciar Sessão";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar Sessão — SGEEP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/css/sgeep-theme.css" rel="stylesheet" />
    <style>
        .auth-shell {
            min-height: 100vh;
            background: var(--sg-canvas);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 32px 16px;
        }
        .auth-card {
            width: 100%;
            max-width: 420px;
            background: var(--sg-canvas);
            border: 1px solid var(--sg-hairline);
            border-radius: var(--sg-radius-lg);
            padding: 40px 36px;
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
        }
        .auth-brand {
            font-family: var(--sg-font-display);
            font-weight: 600;
            font-size: 1.5rem;
            letter-spacing: -0.04em;
            color: var(--sg-ink);
            margin: 0;
        }
        .auth-tagline {
            color: var(--sg-muted);
            font-size: 0.875rem;
            margin: 4px 0 28px;
        }
        .auth-title {
            font-family: var(--sg-font-display);
            font-size: 1.5rem;
            font-weight: 600;
            letter-spacing: -0.03em;
            color: var(--sg-ink);
            margin: 0 0 20px;
        }
    </style>
</head>
<body>
    <div class="auth-shell">
        <div class="auth-card">
            <h1 class="auth-brand">SGEEP</h1>
            <p class="auth-tagline">Sistema de Gestão de Estágios</p>

            <h2 class="auth-title">Iniciar sessão</h2>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="utilizador@escola.pt" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label">Palavra-passe</label>
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="••••••••" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="mb-4 form-check">
                    <input asp-for="Input.RememberMe" class="form-check-input" />
                    <label asp-for="Input.RememberMe" class="form-check-label small text-muted">Lembrar-me</label>
                </div>

                <button id="login-submit" type="submit" class="btn btn-primary w-100">
                    Entrar
                </button>
            </form>

            <p class="text-center text-muted small mt-4 mb-0">
                &copy; @DateTime.Now.Year SGEEP
            </p>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>
