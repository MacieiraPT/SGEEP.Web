@page
@model LogoutModel
@{
    ViewData["Title"] = "Sessão Terminada";
    Layout = null;
}

@if (User.Identity?.IsAuthenticated ?? false)
{
    <form method="post" id="logoutForm"></form>
    <script>document.getElementById('logoutForm').submit();</script>
}
else
{
    <!DOCTYPE html>
    <html lang="pt">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Sessão Terminada — SGEEP</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
        <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
        <link href="~/css/sgeep-theme.css" rel="stylesheet" />
        <style>
            .auth-shell { min-height: 100vh; background: var(--sg-canvas); display: flex; align-items: center; justify-content: center; padding: 32px 16px; }
            .auth-card { width: 100%; max-width: 420px; background: var(--sg-canvas); border: 1px solid var(--sg-hairline); border-radius: var(--sg-radius-lg); padding: 40px 36px; text-align: center; box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04); }
            .auth-brand { font-family: var(--sg-font-display); font-weight: 600; font-size: 1.5rem; letter-spacing: -0.04em; color: var(--sg-ink); margin: 0 0 24px; }
            .check-circle { width: 56px; height: 56px; border-radius: 50%; background: rgba(16, 185, 129, 0.1); display: inline-flex; align-items: center; justify-content: center; color: var(--sg-success); font-size: 1.75rem; margin-bottom: 16px; }
            .auth-title { font-family: var(--sg-font-display); font-size: 1.5rem; font-weight: 600; letter-spacing: -0.03em; color: var(--sg-ink); margin: 0 0 8px; }
            .auth-sub { color: var(--sg-muted); font-size: 0.875rem; margin: 0 0 28px; }
        </style>
    </head>
    <body>
        <div class="auth-shell">
            <div class="auth-card">
                <h1 class="auth-brand">SGEEP</h1>
                <div class="check-circle"><i class="bi bi-check-lg"></i></div>
                <h2 class="auth-title">Sessão terminada</h2>
                <p class="auth-sub">A sua sessão foi encerrada com sucesso.</p>

                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary w-100">
                    Iniciar sessão
                </a>

                <p class="text-muted small mt-4 mb-0">&copy; @DateTime.Now.Year SGEEP</p>
            </div>
        </div>
    </body>
    </html>
}
